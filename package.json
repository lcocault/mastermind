{
  "name": "mastermind",
  "version": "1.0.0",
  "description": "Mastermind game implemented in TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --outfile=dist/bundle.js --minify --target=es2020",
    "package": "npm run bundle && node scripts/package.mjs",
    "test": "jest",
    "start": "tsc --watch"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/jsdom": "^21.1.7",
    "esbuild": "^0.25.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.3",
    "typescript": "^5.5.4"
  }
}
